// 1탄과 2탄이 합쳐진 무시무시한 Base64 코드를 해독하여 진짜 128px 고해상도 아이콘으로 변환하는 장치
function applyBase64Icon128() {
  const img = new Image();
  img.src = ICON_128_BASE64;
  
  img.onload = function() {
    const canvas = new OffscreenCanvas(128, 128);
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, 128, 128);
    
    // 크롬 엔진에 이미지 픽셀 고대로 때려박기 ㅋㅋ
    const imgData = ctx.getImageData(0, 0, 128, 128);
    chrome.action?.setIcon({ imageData: imgData }, () => {
      console.log("🎯 [성공] icon-128 텍스트 코드가 완벽하게 합쳐져 이미지로 재생성되었습니다!");
    });
  };
}

// 확장 프로그램 리로드되거나 작동할 때 주입 장치 가동
chrome.runtime.onInstalled.addListener(() => applyBase64Icon128());
chrome.runtime.onStartup.addListener(() => applyBase64Icon128());
