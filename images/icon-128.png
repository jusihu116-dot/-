// ==========================================
// 🎨 [2탄] 방패 테두리 선 및 X 차단마크 완성
// ==========================================

  // 5. 방패 테두리에 빛나는 하늘색 선 긋기
  ctx.strokeStyle = '#00df89';
  ctx.lineWidth = 5;
  ctx.stroke();

  // 6. 가운데 강력한 화살표 느낌의 대형 X 차단 마크 그리기
  ctx.strokeStyle = '#ffffff';
  ctx.lineWidth = 14;
  ctx.lineCap = 'round'; // 선 끝부분을 둥글게 가공

  // 왼쪽 위에서 오른쪽 아래로 내려가는 대각선
  ctx.beginPath();
  ctx.moveTo(42, 42);
  ctx.lineTo(86, 86);
  ctx.stroke();

  // 오른쪽 위에서 왼쪽 아래로 내려가는 대각선 (화살표 느낌 강조)
  ctx.beginPath();
  ctx.moveTo(86, 42);
  ctx.lineTo(42, 86);
  ctx.stroke();

  // 7. 자바스크립트 도화지에 그린 이미지를 크롬 128 아이콘 데이터로 추출
  const imgData = ctx.getImageData(0, 0, 128, 128);

  // 8. 브라우저 확장 프로그램 실제 아이콘으로 강제 등록! ㅋㅋ
  chrome.action?.setIcon({ imageData: imgData }, () => {
    console.log("🚀 [성공] 이미지가 자바스크립트 코드로 128 재생성 완료! ㅋㅋ");
  });
}

// 브라우저에 프로그램이 켜지거나 새로고침 될 때 자동으로 아이콘 그리게 만들기
chrome.runtime.onInstalled.addListener(() => generate128Icon());
chrome.runtime.onStartup.addListener(() => generate128Icon());
